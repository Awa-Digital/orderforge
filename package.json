{
  "name": "app",
  "private": "true",
  "dependencies": {
    "@activeadmin/activeadmin": "4.0.0-beta16",
    "activeadmin-awesome": "1.0.0",
    "autoprefixer": "^10.4.20",
    "bootstrap": "^5.3.3",
    "bootstrap-icons": "^1.11.3",
    "bulma": "^1.0.3",
    "flowbite": "^3.0.0",
    "nodemon": "^3.1.9",
    "postcss": "^8.5.1",
    "postcss-cli": "^11.0.0",
    "postcss-import": "^16.1.0",
    "postcss-nesting": "^13.0.1",
    "sass": "^1.83.4",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "@tailwindcss/cli": "^4.1.10",
    "yarn": "^1.22.22"
  },
  "scripts": {
    "build:css:admin": "npx @tailwindcss/cli -i ./app/assets/stylesheets/active_admin.css -o ./app/assets/builds/active_admin.css --minify -c ./config/tailwind.config.js",
    "build:css:tailwind": "npx @tailwindcss/cli -i ./app/assets/tailwind/application.css -o ./app/assets/builds/application.tailwind.css --minify -c ./config/tailwind.config.js",
    "build:css:compile": "sass ./app/assets/stylesheets/application.bootstrap.scss:./app/assets/builds/application.css --no-source-map --load-path=node_modules",
    "build:css:prefix": "postcss ./app/assets/builds/application.css --use=autoprefixer --output=./app/assets/builds/application.css",
    "build:css": "yarn build:css:admin && yarn build:css:tailwind && yarn build:css:compile && yarn build:css:prefix",
    "watch:css": "nodemon --watch app/assets/**/*.{css,scss} --exec \"yarn build:css\""
  },
  "browserslist": [
    "defaults"
  ],
  "engines": {
    "node": ">23.0.0",
    "npm": "^11.5.1",
    "yarn": "^1.22.22"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
