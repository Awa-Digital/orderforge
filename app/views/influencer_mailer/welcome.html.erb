<!-- Email Container -->
<div style="max-width: 600px; margin: 0 auto; font-family: Arial, sans-serif; color: #333333; line-height: 1.6;">
  <!-- Welcome Section -->
  <div style="padding: 20px;">
    <h2 style="color: #1a1a1a; margin-bottom: 20px;">Welcome to <%= AppBranding::NAME %> Affiliate Program!</h2>
    <p style="margin-bottom: 15px;">Hello <%= @user.name %>,</p>
    <p style="margin-bottom: 25px;">We're excited to have you join our affiliate program! This is the beginning of a great partnership. Below are the steps to get your account fully approved and start earning.</p>
  </div>

  <!-- Video Section -->
  <div style="margin-bottom: 30px; text-align: center;">
    <a href="https://www.youtube.com/watch?v=YW0EuZvFcMM" target="_blank" style="text-decoration: none;">
      <img src="https://#{AppBranding::MEDIA_CDN_URL}/bg.png" alt="<%= AppBranding::NAME %> Affiliate Approval Video" style="max-width: 100%; height: auto; border-radius: 8px;" />
      <p style="color: #666; margin-top: 10px;">👆 Click to watch our sample verification video on YouTube</p>
    </a>
  </div>

  <!-- Steps Section -->
  <div style="padding: 20px; background-color: #f9f9f9; border-radius: 8px;">
    <h3 style="color: #1a1a1a; margin-bottom: 20px;">Next Steps for Approval</h3>

    <div style="margin-bottom: 15px;">
      <p style="margin: 0;">
        📝 <strong>Step 1:</strong> Submit Verification Document
      </p>
    </div>

    <div style="margin-bottom: 15px;">
      <p style="margin: 0;">
        🎥 <strong>Step 2:</strong> Watch & Create - Watch the verification sample video above and create your own video
      </p>
    </div>

    <div style="margin-bottom: 15px;">
      <p style="margin: 0;">
        🌟 <strong>Step 3:</strong> Share & Submit - Post your video on social media then submit the video link on your affiliate page
      </p>
    </div>

    <div style="margin-bottom: 15px;">
      <p style="margin: 0;">
        ✨ <strong>Step 4:</strong> Get Approved - Wait for final approval and start sharing your link to earn commissions instantly
      </p>
    </div>
  </div>

  <!-- Status Section -->
  <div style="padding: 20px; margin-top: 20px; background-color: #fff3cd; border-radius: 8px;">
    <p style="margin: 0; color: #856404;">
      ⏳ Once you add your verification link on your <a href="<%= AppBranding::URL %>/affiliate" style="color: #856404; font-weight: bold;">profile</a>, a member of our staff will review and approve your account.
    </p>
  </div>

  <!-- Footer -->
  <div style="padding: 20px; margin-top: 20px; text-align: center; color: #666;">
    <p style="margin: 0;">If you have any questions, please don't hesitate to contact our support team.</p>
  </div>
</div>
