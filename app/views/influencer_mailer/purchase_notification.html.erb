<!-- Email Container -->
<div style="max-width: 600px; margin: 0 auto; font-family: Arial, sans-serif; color: #333333; line-height: 1.6;">
  <!-- Header -->
  <div style="padding: 20px;">
    <h2 style="color: #1a1a1a; margin-bottom: 20px; font-size: 22px;"><%= @first_name %>, You earned ₦<%= number_with_delimiter(@commission_amount, delimiter: ',') %>.</h2>
    <p style="margin-bottom: 15px;">A purchase has been completed through your affiliate link. Your commission for this order has been credited to your affiliate balance.</p>
  </div>

  <!-- Commission Summary -->
  <div style="padding: 20px; background-color: #f5f5f5; border-radius: 8px; margin-bottom: 24px; border: 1px solid #e0e0e0;">
    <h3 style="color: #1a1a1a; margin-bottom: 16px; font-size: 16px; font-weight: 600;">Transaction summary</h3>
    <table style="width: 100%; border-collapse: collapse;">
      <tr>
        <td style="padding: 10px 0; color: #555; font-size: 14px;">Order reference</td>
        <td style="padding: 10px 0; text-align: right; font-weight: 600; font-size: 14px;"><%= @order.reference %></td>
      </tr>
      <tr>
        <td style="padding: 10px 0; color: #555; font-size: 14px;">Order value</td>
        <td style="padding: 10px 0; text-align: right; font-weight: 600; font-size: 14px;">₦<%= number_with_delimiter(@order.total, delimiter: ',') %></td>
      </tr>
      <tr>
        <td style="padding: 10px 0; color: #555; font-size: 14px;">Commission</td>
        <td style="padding: 10px 0; text-align: right; font-weight: 600; font-size: 14px; color: #2e7d32;">₦<%= number_with_delimiter(@commission_amount, delimiter: ',') %></td>
      </tr>
    </table>
  </div>

  <!-- Next steps -->
  <div style="padding: 20px;">
    <p style="margin-bottom: 12px; font-size: 14px; color: #555;">You can view your current balance, transaction history, and request a withdrawal at any time from your affiliate dashboard.</p>
    <p style="margin-bottom: 0; font-size: 14px;">
      <a href="<%= AppBranding::URL %>/affiliate" style="color: #1a1a1a; font-weight: 600; text-decoration: underline;">View affiliate dashboard</a>
    </p>
  </div>

  <!-- Footer -->
  <div style="padding: 24px 20px; margin-top: 8px; border-top: 1px solid #e0e0e0; text-align: center; color: #666; font-size: 13px;">
    <p style="margin: 0;">Thank you for partnering with <%= AppBranding::NAME %>.</p>
    <p style="margin: 8px 0 0 0;">If you have any questions about your commission or account, please contact our affiliate support team.</p>
  </div>
</div>
