<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <style>
      /* Email styles need to be inline */
      body {
        background-color: rgba(255, 39, 9, 1);
        padding: 0;
        margin: 0;
        font-family: "Helvetica";
      }
      #email-main {
        max-width: 768px;
        background: #fff;
        padding: 20px 40px;
        margin: 0px auto;
      }
    </style>
  </head>

  <body>
    <div id="email-main">
      <%= render 'layouts/email/header' %> <%= yield %> <%= render 'layouts/email/footer' %>
    </div>
  </body>
</html>
