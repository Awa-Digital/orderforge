<div id="receipt-body">
  <% if AppBranding::MEDIA_CDN_URL.present? %>
    <div class="ad">
      <img src="<%= AppBranding::MEDIA_CDN_URL %>/welcome.png" alt="welcome email" />
    </div>
  <% end %>
  <h3>Welcome to <%= AppBranding::NAME %>!</h3>
  <p class="user-greeting">Hello <%=@user.first_name%>,</p>
  <p class="user-greeting-info">
    We are happy you have signed up on our website or mobile application
  </p>
  <br>
  <p class="user-greeting-info">
    To verify your email address on our application, click the button below to confirm your account. If you have not signed up on the <%= AppBranding::NAME %> website, please do not click this button. You can also reach out to us via our support channels and someone from our team will be able to assist you.
  </p>
  <div class="reset-details">
    <a class="action-button" href="<%= @user.verification_url %>">Verify your email</a>

    <p class="user-greeting-info">
    or click on this link to verify your password:  <a href="<%= @user.verification_url %>"><%= @user.verification_url %></a>
  </p>
  </div>
</div>
