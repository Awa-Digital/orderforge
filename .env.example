# OrderForge — Core Commerce Engine
# Copy to .env and fill in values for your deployment.

# --- Branding (override per tenant/deployment) ---
APP_NAME=OrderForge
APP_URL=http://localhost:3000
API_HOST=localhost:3000
ADMIN_SITE_TITLE=OrderForge Admin
MAILER_HOST=localhost:3000
MAILER_DOMAIN=localhost
MEDIA_PREFIX=media
MEDIA_SUBFOLDER=local
MEDIA_CDN_URL=
DEFAULT_AVATAR_URL=
DEFAULT_AD_IMAGE_URL=
AFFILIATE_URL=http://localhost:3000/affiliate
SUPPORT_EMAIL=support@example.com
NOREPLY_FROM=noreply@example.com
OPS_EMAIL=orders@example.com
DISPATCH_EMAIL=dispatch@example.com
STATUS_EMAIL=status@example.com
SENDGRID_FROM_EMAIL=noreply@example.com

# --- Rails ---
SECRET_KEY_BASE=change-me-in-production
RAILS_ENV=development
RAILS_MAX_THREADS=5

# --- Database ---
PGDATABASE=order_forge_development
PGDBUSER=
PGDBPASS=
PGHOST=localhost
# DATABASE_URL=postgres://user:pass@localhost:5432/order_forge_development

# --- Redis / Sidekiq ---
REDIS_URL=redis://localhost:6379/0

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Admin panel ---
ADMIN_APP=true

# --- Email (SMTP) ---
GMAIL_EMAIL=
GMAIL_PASSWORD=
RECEIPTS_EMAIL=
RECEIPTS_PASSWORD=
NOTIFY_EMAIL=
NOTIFY_PASSWORD=
WEB_EMAIL=
WEB_PASSWORD=
NOREPLY_EMAIL=
NOREPLY_PASSWORD=
AWADIGITAL_EMAIL=
AWADIGITAL_EMAIL_PASSWORD=

# --- SendGrid ---
SENDGRID_API_KEY=

# --- Payments ---
PSPK=
PSSK=
PSTK_URL=https://api.paystack.co
PSTK_TOKEN=
FLW_PUBLIC_KEY=
FLW_SECRET_KEY=
FLW_ENCRYPTION_KEY=

# --- SMS (Termii) ---
TERMII_KEY=
TERMII_SENDER_ID=

# --- File storage (DigitalOcean Spaces / S3-compatible) ---
DO_FOG_KEY=
DO_FOG_SECRET=
DO_FOG_REGION=
DO_FOG_ENDPOINT=
DO_FOG_NAME=

# --- Cloudinary (optional) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Firebase / FCM push notifications ---
FIREBASE_API_TOKEN=
FIREBASE_CREDENTIALS=/path/to/firebase-credentials.json
FIREBASE_PROJECT_ID=

# --- Integrations ---
SLACK_API_TOKEN=
META_TOKEN=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=ngn
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=

# --- Forest Admin (optional, legacy) ---
FOREST_ENV_SECRET=
FOREST_AUTH_SECRET=
